// 6) Realice un algoritmo que me permita calcular el perímetro y la superficie de un cuadrado
Algoritmo cuadrado
	Definir lado, perimetro, superficie Como Real
	Escribir "Ingresá el lado del cuadrado"
	Leer lado
	perimetro <- 4 * lado
	superficie <- lado * lado
	Escribir "Perímetro: ", perimetro
	Escribir "Superficie: ", superficie
FinAlgoritmo
