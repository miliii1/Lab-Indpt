Algoritmo Ej3_guia3
	
	Definir num1, num2 Como Real
	Escribir "Ingrese un numero real "
	Leer num1
	Escribir "Ingrese otro numero real"
	Leer num2
	
	Escribir "La suma es: ", num1+num2 
	Escribir "La resta es: ", num1-num2
	Escribir "El producto es: ", num1*num2
	
	Si num2<>0 Entonces
		Escribir "El cociente es:  ", num1/num2
	SiNo
		Escribir "No se puede realizar la division"
	FinSi
	
	
FinAlgoritmo
