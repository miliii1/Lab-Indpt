Algoritmo Ej4_guia3
	
	Definir num1, num2 Como Real
	Escribir "Ingrese un numero: "
	Leer num1
	Escribir "Ingrese otro numero: "
	Leer num2
	
	
	Si num1<>num2 Entonces
		Si num1>num2 Entonces
			Escribir num1, " es mayor que ", num2
		SiNo
			Escribir num1, " es menor que ", num2
		FinSi
	SiNo
		Escribir "Los numeros son iguales"
	FinSi
	
FinAlgoritmo
